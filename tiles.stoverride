name: Custom Tiles

tiles:
  - name: instagram-check
    title: Instagram
    icon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Instagram.png
    collapsed: true
    url: https://www.instagram.com

script-providers:
  instagram-check:
    url: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/script/instagram.js
    interval: 86400
