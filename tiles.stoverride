#SUBSCRIBED https://fastly.jsdelivr.net/gh/stepasid/stash-tiles@main/tiles.stoverride
name: Custom Tiles

tiles:
  - name: Instagram-Check
    title: Instagram
    icon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Instagram.png
    collapsed: true
    url: https://www.instagram.com

  - name: YouTube-Check
    title: YouTube
    icon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/YouTube.png
    collapsed: true
    url: https://www.youtube.com/generate_204

  - name: ChatGPT-Web-Check
    title: ChatGPT
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/chatgpt.png
    collapsed: true
    url: https://chatgpt.com

  - name: Claude-Check
    title: Claude
    icon: https://cdn.jsdelivr.net/gh/selfhst/icons/png/claude.png
    collapsed: true
    url: https://claude.ai

  - name: NotebookLM-Check
    title: NotebookLM
    icon: https://ssl.gstatic.com/docs/documents/images/kix-favicon7.ico
    collapsed: true
    url: https://notebooklm.google.com

  - name: Telegram-Check
    title: Telegram
    icon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Telegram.png
    collapsed: true
    url: https://web.telegram.org

  - name: WhatsApp-Check
    title: WhatsApp
    icon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/WhatsApp.png
    collapsed: true
    url: https://web.whatsapp.com

  - name: Element-Classic-Check
    title: Element Classic
    icon: https://element.io/images/favicon.ico
    collapsed: true
    url: https://app.element.io/#/user/@user17:elementout.ru
